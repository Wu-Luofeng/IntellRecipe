# Copy this file to deploy/env.sh on the server, then adjust values.

export APP_HOME=/opt/intellrecipe
# Four JVMs on one 4GB host: keep heaps small. Raise only if you add RAM or run fewer services.
export JAVA_OPTS="-Xms128m -Xmx256m -Duser.timezone=Asia/Shanghai"

export MYSQL_HOST=127.0.0.1
export MYSQL_PORT=3307
export MYSQL_DATABASE=intell_recipe
export MYSQL_USERNAME=root
export MYSQL_PASSWORD=root

export REDIS_HOST=127.0.0.1
export REDIS_PORT=6379
export REDIS_PASSWORD=123321
export REDIS_DATABASE=0

export NACOS_SERVER_ADDR=127.0.0.1:8848

export RABBITMQ_HOST=127.0.0.1
export RABBITMQ_PORT=5672
export RABBITMQ_USERNAME=root
export RABBITMQ_PASSWORD=123456
export RABBITMQ_VIRTUAL_HOST=/

export ELASTICSEARCH_URIS=http://127.0.0.1:9200

# Set to false when Elasticsearch container is not running (e.g. 4GB VPS).
# Also disables Spring Data Elasticsearch repositories (see item-service application.yml).
export ITEM_ELASTICSEARCH_ENABLED=false

# Must match docker/.env: RABBITMQ_DEFAULT_USER and RABBITMQ_DEFAULT_PASS (first boot only).
# If login refused, recreate rabbitmq data dir or align credentials below with the broker.

# Fill these on a real server only. Do not commit real secrets.
export ALIYUN_SMS_ACCESS_KEY_ID=
export ALIYUN_SMS_ACCESS_KEY_SECRET=
export ALIYUN_SMS_SIGN_NAME=阿里云短信测试
export ALIYUN_SMS_TEMPLATE_CODE=SMS_154950909

# 头像上传配置：UPLOAD_DIR 为服务器本地存储路径，UPLOAD_URL_PREFIX 为 Nginx 对外暴露的路径
# Nginx 中需配置 location /uploads/ { alias /home/ubuntu/IntellRecipe/uploads/; }
export UPLOAD_DIR=/home/ubuntu/IntellRecipe/uploads
export UPLOAD_URL_PREFIX=http://129.204.203.184/uploads
